{
  "builds": [
    { "src": "app/main.py", "use": "@vercel/python", "config": { "maxDuration": 60 } }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "app/main.py" }
  ],
  "crons": [
    { "path": "/api/cron/seed-minds", "schedule": "0 0 * * *" },
    { "path": "/api/cron/discover", "schedule": "0 6 * * *" },
    { "path": "/api/cron/embed-minds", "schedule": "0 1 * * *" }
  ]
}
